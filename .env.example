# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE SHHETS & GMAIL AUTOMATED USER SYNC CONTROL (Admin agencialeps@gmail.com)
# Retrieve these values in Google Cloud Console -> APIs & Credentials -> OAuth 2.0 Client
OAUTH_CLIENT_ID=""
OAUTH_CLIENT_SECRET=""
# Use OAuth Playground or code flow to generate a long-lived refresh token with Sheets & Gmail scopes
OAUTH_REFRESH_TOKEN=""
# The secure ID of the spreadsheet to store registrations (obtainable from URL)
SPREADSHEET_ID=""
# Notification destination email (defaults to agencialeps@gmail.com)
NOTIFY_EMAIL="agencialeps@gmail.com"

# HOTMART & SESSION SECURITY CONFIGURATION
# JWT secret for signing session tokens
JWT_SECRET=""
# Webhook verification token to authorize Hotmart payload
HOTMART_WEBHOOK_SECRET=""

# ADMINISTRATOR SECURITY & EMAIL CONFIGURATION
# The exclusive password for contacto@tupodermental.club master admin login
ADMIN_PASSWORD=""
# SMTP Server settings (Fallback or Transition from Google Gmail API)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER="contacto@tupodermental.club"
SMTP_PASS=""
SMTP_FROM="contacto@tupodermental.club"

